# App
DATABASE_URL=file:./data/aicomic.db
UPLOAD_DIR=./uploads

# SiliconFlow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# API 并发控制（避免触发频率限制）
# 生成首尾帧提示词的并发数（AI 文本接口，默认 2）
KEYFRAME_PROMPTS_CONCURRENCY=2
# 批量生成视频提示词的并发数（AI 文本+图像接口，默认 2）
VIDEO_PROMPT_CONCURRENCY=2
# 批量生成帧的并发数（AI 图像接口，默认 2）
FRAME_GENERATE_CONCURRENCY=2